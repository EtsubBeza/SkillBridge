// OPPORTUNITIES API TESTING

### Create Opportunity
POST http://localhost:5051/api/opportunities
Content-Type: application/json

{
  "employerProfileId": 1,
  "title": "Junior ASP.NET Developer",
  "description": "Looking for recent graduates with .NET experience.",
  "requiredSkills": "ASP.NET Core, SQL Server, Git",
  "location": "Addis Ababa",
  "employmentType": "Full-Time",
  "salary": 25000
}

###

GET http://localhost:5051/api/opportunities

###

GET http://localhost:5051/api/opportunities/1

###

PUT http://localhost:5051/api/opportunities/1
Content-Type: application/json

{
  "title": "Junior Backend Developer",
  "description": "Looking for graduates interested in backend development.",
  "requiredSkills": "ASP.NET Core, SQL Server",
  "location": "Addis Ababa",
  "employmentType": "Full-Time",
  "salary": 30000,
  "isActive": true
}

###

DELETE http://localhost:5051/api/opportunities/1