```gitignore
############################
# Build results
############################
bin/
obj/

############################
# User-specific files
############################
*.user
*.suo
*.userosscache
*.sln.docstates

############################
# Visual Studio
############################
.vs/

############################
# Visual Studio Code
############################
.vscode/

############################
# Rider
############################
.idea/

############################
# Logs
############################
*.log

############################
# ASP.NET Core
############################
appsettings.Development.json

############################
# Publish output
############################
publish/

############################
# NuGet
############################
*.nupkg
packages/

############################
# Test results
############################
TestResults/

############################
# OS generated files
############################
Thumbs.db
Desktop.ini
.DS_Store

############################
# Environment files
############################
.env
.env.*

############################
# Node.js (for Angular later)
############################
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
package-lock.json

############################
# Angular build output
############################
dist/
coverage/

############################
# Temporary files
############################
*.tmp
*.temp
```
